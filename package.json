{
  "name": "sillytavern-discord-bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run build:server && npm run build:ui",
    "build:server": "tsc -p tsconfig.server.json",
    "build:ui": "vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "smoke:claude-proxy": "node scripts/smoke-claude-proxy.mjs",
    "smoke:discord": "node scripts/register-discord-commands.mjs --smoke",
    "pack": "node scripts/pack-extension.mjs",
    "install-local": "node scripts/install-local.mjs",
    "register:discord": "node scripts/register-discord-commands.mjs"
  },
  "dependencies": {
    "discord.js": "^14.19.3",
    "express": "^4.21.2",
    "write-file-atomic": "^5.0.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.3",
    "@vitest/coverage-v8": "^3.1.2",
    "eslint": "^9.25.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.0",
    "vite": "^6.3.4",
    "vitest": "^3.1.2"
  }
}
